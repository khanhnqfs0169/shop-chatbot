# Sao chep file nay thanh .env roi dien thong tin that vao
# =====================================================

# 1. Claude API Key — lay tai https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# 2. Facebook Page Access Token
#    Vao: https://developers.facebook.com/ > App > Messenger > Settings > Access Tokens
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token

# 3. Verify Token — tu dat, dung khi cai webhook Facebook
FB_VERIFY_TOKEN=my_shop_verify_token_2024

# 4. Ten shop
SHOP_NAME=Shop thoi trang ABC

# 5. File du lieu san pham
PRODUCTS_FILE=products.xlsx

# 6. Model Claude (haiku = nhanh & re | sonnet = thong minh hon)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# 7. Cong server
PORT=5000

# --- BAO CAO EMAIL (Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
REPORT_EMAIL_TO=owner@gmail.com

# --- GOOGLE SHEETS (tuy chon) ---
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_FILE=credentials.json
